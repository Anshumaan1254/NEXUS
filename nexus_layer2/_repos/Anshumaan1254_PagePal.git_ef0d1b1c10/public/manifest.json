{
  "manifest_version": 3,
  "name": "PagePal",
  "short_name": "PagePal",
  "version": "2.0",
  "description": "Your AI-powered reading companion - summarize pages and explain complex terms instantly.",
  "trial_tokens": [
    "YOUR TRIAL TOKEN HERE"
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Open PagePal",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ]
    }
  ]
}
