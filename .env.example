# Nexus Decision Provenance Engine - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# GitHub API Configuration
# ============================================================================
# Required for repository cloning and commit history fetching
# Get your token at: https://github.com/settings/tokens
# Scopes needed: repo (for private repos) or public_repo (for public only)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# ============================================================================
# LLM API Configuration (Choose at least one)
# ============================================================================

# OpenAI API (Recommended for best results)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# Anthropic Claude API (Alternative)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4096

# IBM watsonx.ai (For IBM Granite models)
# Get credentials at: https://cloud.ibm.com/watsonx
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-13b-chat-v2

# Default LLM backend to use (openai, anthropic, or watsonx)
DEFAULT_LLM_BACKEND=openai

# ============================================================================
# Application Configuration
# ============================================================================

# FastAPI settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS settings (comma-separated origins)
# Development: Use * to allow all origins
# Production: Specify exact origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cache settings
CACHE_TTL_HOURS=24
MAX_CONCURRENT_ANALYSES=10

# Repository cloning
TEMP_REPO_DIR=/tmp/nexus-repos
MAX_REPO_SIZE_MB=1024

# ============================================================================
# Analysis Configuration Defaults
# ============================================================================

DEFAULT_ANALYSIS_WINDOW=2 years
DEFAULT_MIN_DPRS=25
DEFAULT_PRIORITY_AREAS=all

# ============================================================================
# Logging Configuration
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=nexus.log

# ============================================================================
# Rate Limiting
# ============================================================================

# API rate limits (requests per minute)
RATE_LIMIT_ANALYZE=10
RATE_LIMIT_GET=100

# GitHub API rate limit handling
GITHUB_RATE_LIMIT_BUFFER=100

# LLM API retry configuration
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_SECONDS=2

# ============================================================================
# Development/Testing
# ============================================================================

# Set to 'true' to enable debug mode
DEBUG=false

# Set to 'true' to use mock LLM responses (for testing without API keys)
USE_MOCK_LLM=false

# Test repository for development
TEST_REPO_URL=https://github.com/psf/requests

# ============================================================================
# Security
# ============================================================================

# Secret key for session management (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# JWT token expiration (in hours)
TOKEN_EXPIRATION_HOURS=24

# ============================================================================
# Performance Tuning
# ============================================================================

# Number of worker processes for uvicorn
WORKERS=4

# Maximum request body size (in MB)
MAX_REQUEST_SIZE_MB=10

# Timeout for LLM API calls (in seconds)
LLM_TIMEOUT_SECONDS=60

# Timeout for GitHub API calls (in seconds)
GITHUB_TIMEOUT_SECONDS=30

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable specific features
ENABLE_CAUSAL_GRAPH=true
ENABLE_DECAY_MONITOR=true
ENABLE_EXPORT=true

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Enable metrics collection
ENABLE_METRICS=false

# Metrics endpoint (if enabled)
METRICS_PORT=9090

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ============================================================================
# Notes
# ============================================================================
# 1. Never commit the actual .env file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Use different keys for development, staging, and production
# 4. Monitor your API usage to avoid unexpected costs
# 5. Set appropriate rate limits based on your API tier